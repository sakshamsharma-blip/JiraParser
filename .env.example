# Copy to .env and fill in real values. Never commit .env.

# Your Atlassian email (the one you log into Jira with)
JIRA_EMAIL=you@company.com

# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=paste_token_here

# Example: https://yourcompany.atlassian.net
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Full Google Sheet URL (Share → Anyone with the link can View)
# Example: https://docs.google.com/spreadsheets/d/abc123.../edit#gid=0
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/REPLACE_ME/edit#gid=0
