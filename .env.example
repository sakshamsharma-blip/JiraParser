# Copy to .env to prefill the UI / CLI (optional).
# Never commit .env — each teammate uses their own credentials.

JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=paste_token_here
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Optional default sheet for the UI / CLI
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/REPLACE_ME/edit#gid=0
